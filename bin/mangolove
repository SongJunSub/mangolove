#!/bin/bash
# ─────────────────────────────────────────────
# 🥭 MangoLove — Autonomous Development Agent
# Powered by Claude Code
# https://github.com/SongJunSub/mangolove
# ─────────────────────────────────────────────

set -eo pipefail

MANGOLOVE_VERSION="0.3.0"
MANGOLOVE_DIR="${MANGOLOVE_DIR:-$HOME/.mangolove}"
SYSTEM_PROMPT_FILE="$MANGOLOVE_DIR/prompts/system-prompt.md"
WORK_LOGGER="$MANGOLOVE_DIR/lib/work-logger.sh"
PROFILE_MANAGER="$MANGOLOVE_DIR/lib/profile-manager.sh"
PLUGIN_MANAGER="$MANGOLOVE_DIR/lib/plugin-manager.sh"
SKILL_MANAGER="$MANGOLOVE_DIR/lib/skill-manager.sh"
BANNER_SCRIPT="$MANGOLOVE_DIR/lib/banner.sh"

# ─────────────────────────────────────────────
# Load user configuration
# ─────────────────────────────────────────────
MANGOLOVE_AUTO_LOG=true
MANGOLOVE_SHOW_BANNER=true
MANGOLOVE_EXTRA_PROMPT=""
MANGOLOVE_MODEL=""
MANGOLOVE_EFFORT=""
MANGOLOVE_MODE=""

if [ -f "$MANGOLOVE_DIR/config.sh" ]; then
    if bash -n "$MANGOLOVE_DIR/config.sh" 2>/dev/null; then
        # shellcheck source=/dev/null
        source "$MANGOLOVE_DIR/config.sh"
    else
        echo -e "\033[38;5;220mWarning: config.sh has syntax errors. Using defaults.\033[0m" >&2
        echo "  Run: bash -n ~/.mangolove/config.sh  to see errors." >&2
    fi
fi

# ─────────────────────────────────────────────
# Preflight check
# ─────────────────────────────────────────────
check_dependencies() {
    if ! command -v claude &> /dev/null; then
        echo ""
        echo -e "\033[38;5;203m✗ Claude Code is not installed.\033[0m"
        echo ""
        echo "  MangoLove requires Claude Code to run."
        echo "  Install it from: https://claude.ai/claude-code"
        echo ""
        exit 1
    fi
}

# ─────────────────────────────────────────────
# Build the full system prompt
# ─────────────────────────────────────────────
build_system_prompt() {
    local base_prompt=""
    if [ -f "$SYSTEM_PROMPT_FILE" ]; then
        base_prompt=$(cat "$SYSTEM_PROMPT_FILE")
    else
        base_prompt="You are MangoLove, an autonomous development agent. Analyze, plan, execute, and verify tasks autonomously."
    fi

    # Load project profile
    local project_context=""
    project_context=$(bash "$PROFILE_MANAGER" load 2>/dev/null) || true

    # Build work log instruction
    local log_instruction=""
    if [ "$MANGOLOVE_AUTO_LOG" = "true" ]; then
        log_instruction="

## Work Logging
After completing significant tasks, update the daily work log at:
\`~/.mangolove/logs/repo/logs/$(date '+%Y/%m')/$(date '+%Y-%m-%d').md\`
with a brief summary of what was accomplished."
    fi

    # Load mode-specific prompt
    local mode_prompt=""
    if [ -n "$MANGOLOVE_MODE" ]; then
        local mode_file="$MANGOLOVE_DIR/prompts/modes/${MANGOLOVE_MODE}.md"
        if [ -f "$mode_file" ]; then
            mode_prompt=$(cat "$mode_file")
        fi
    fi

    # Combine
    local full_prompt="${base_prompt}"

    if [ -n "$mode_prompt" ]; then
        full_prompt="${full_prompt}

---

${mode_prompt}"
    fi

    if [ -n "$project_context" ]; then
        full_prompt="${full_prompt}

---

## Active Project Profile
${project_context}"
    else
        full_prompt="${full_prompt}

---

## No Project Profile Found
The current directory does not match any known project profile.
On your first response, briefly analyze the project structure and offer to create a profile at:
\`~/.mangolove/projects/{name}.md\`"
    fi

    full_prompt="${full_prompt}${log_instruction}"

    # Load skill prompt additions
    local skill_additions=""
    skill_additions=$(bash "$SKILL_MANAGER" prompts 2>/dev/null) || true
    if [ -n "$skill_additions" ]; then
        full_prompt="${full_prompt}

---

## Skill Instructions
${skill_additions}"
    fi

    # Load plugin prompt additions
    local plugin_additions=""
    plugin_additions=$(bash "$PLUGIN_MANAGER" prompts 2>/dev/null) || true
    if [ -n "$plugin_additions" ]; then
        full_prompt="${full_prompt}

---

## Plugin Instructions
${plugin_additions}"
    fi

    if [ -n "$MANGOLOVE_EXTRA_PROMPT" ]; then
        full_prompt="${full_prompt}

---

## User Custom Instructions
${MANGOLOVE_EXTRA_PROMPT}"
    fi

    echo "$full_prompt"
}

# ─────────────────────────────────────────────
# Subcommands
# ─────────────────────────────────────────────
show_version() {
    echo "🥭 MangoLove v${MANGOLOVE_VERSION}"
}

show_help() {
    echo ""
    echo -e "\033[38;5;208m\033[1m🥭 MangoLove\033[0m v${MANGOLOVE_VERSION} — Autonomous Development Agent"
    echo ""
    echo "Usage:"
    echo "  mangolove                     Start interactive session"
    echo "  mangolove [prompt]            Start with a specific task"
    echo "  mangolove -p [prompt]         Print mode (non-interactive)"
    echo ""
    echo "Commands:"
    echo "  mangolove projects            List project profiles"
    echo "  mangolove profile add         Add a new project profile"
    echo "  mangolove profile auto [dir]  Auto-generate profile from project scan"
    echo "  mangolove profile export <n>  Export profile as .mangolove.md for team"
    echo "  mangolove profile import [f]  Import .mangolove.md to personal profiles"
    echo "  mangolove profile remove <n>  Remove a project profile"
    echo "  mangolove skill               List installed skills"
    echo "  mangolove skill install <url> Install a skill pack from git URL"
    echo "  mangolove skill create <name> Create a new skill pack template"
    echo "  mangolove skill remove <name> Remove a skill pack"
    echo "  mangolove skill update [name] Update skill pack(s)"
    echo "  mangolove plugin              List installed plugins"
    echo "  mangolove plugin create <n>   Create a new plugin from template"
    echo "  mangolove plugin enable <n>   Enable a plugin"
    echo "  mangolove plugin disable <n>  Disable a plugin"
    echo "  mangolove log init            Initialize work log repository"
    echo "  mangolove log view            Open work logs in browser"
    echo "  mangolove log search <term>   Search work logs"
    echo "  mangolove log recent          Show recent sessions"
    echo "  mangolove update              Update MangoLove to latest version"
    echo "  mangolove doctor              Check installation health"
    echo "  mangolove help                Show this help"
    echo "  mangolove --version           Show version"
    echo ""
    echo "Modes:"
    echo "  mangolove --mode review       Code review mode"
    echo "  mangolove --mode debug        Debug & root-cause analysis mode"
    echo "  mangolove --mode refactor     Refactoring mode"
    echo "  mangolove --mode security     Security audit mode"
    echo "  mangolove --mode plan         Planning mode"
    echo "  mangolove --mode pr           PR creation mode"
    echo "  mangolove --mode tdd          Test-driven development mode"
    echo "  mangolove --mode strict       Strict mode (auto lint/test/build)"
    echo "  mangolove --mode docs         Documentation sync mode"
    echo ""
    echo "Options (passed through to Claude Code):"
    echo "  -c, --continue                Continue last conversation"
    echo "  -r, --resume                  Resume a session"
    echo "  --model [model]               Select model"
    echo "  --effort [level]              Set effort level"
    echo ""
    echo "Examples:"
    echo "  mangolove"
    echo "  mangolove \"예약 API 리팩토링해줘\""
    echo "  mangolove -c"
    echo "  mangolove --model opus --effort max \"시스템 전체 분석해줘\""
    echo ""
    echo "Config: ~/.mangolove/config.sh"
    echo "Docs:   https://github.com/SongJunSub/mangolove"
    echo ""
}

do_update() {
    echo "🔄 Updating MangoLove..."
    if [ -d "$MANGOLOVE_DIR/.git" ]; then
        cd "$MANGOLOVE_DIR"
        git pull origin main
        echo "✅ Updated to latest version."
    else
        echo "⚠️  MangoLove was not installed via git."
        echo "   Re-install: curl -fsSL https://raw.githubusercontent.com/SongJunSub/mangolove/main/install.sh | bash"
    fi
}

do_doctor() {
    echo ""
    echo -e "\033[38;5;208m\033[1m🥭 MangoLove Doctor\033[0m"
    echo -e "\033[2m──────────────────────────────────────\033[0m"

    # Check Claude Code
    if command -v claude &> /dev/null; then
        local cv
        cv=$(claude --version 2>/dev/null)
        echo -e "  \033[38;5;113m✓\033[0m Claude Code: ${cv}"
    else
        echo -e "  \033[38;5;203m✗\033[0m Claude Code: not found"
    fi

    # Check GitHub CLI
    if command -v gh &> /dev/null; then
        local gv
        gv=$(gh --version 2>/dev/null | head -1)
        echo -e "  \033[38;5;113m✓\033[0m GitHub CLI: ${gv}"

        if gh auth status &> /dev/null; then
            echo -e "  \033[38;5;113m✓\033[0m GitHub Auth: authenticated"
        else
            echo -e "  \033[38;5;203m✗\033[0m GitHub Auth: not authenticated"
        fi
    else
        echo -e "  \033[38;5;220m△\033[0m GitHub CLI: not found (optional, for work logging)"
    fi

    # Check Git
    if command -v git &> /dev/null; then
        echo -e "  \033[38;5;113m✓\033[0m Git: $(git --version)"
    else
        echo -e "  \033[38;5;203m✗\033[0m Git: not found"
    fi

    # Check MangoLove files
    echo ""
    echo -e "  \033[2mInstallation:\033[0m"
    [ -f "$SYSTEM_PROMPT_FILE" ] && echo -e "  \033[38;5;113m✓\033[0m System prompt" || echo -e "  \033[38;5;203m✗\033[0m System prompt missing"
    [ -f "$BANNER_SCRIPT" ] && echo -e "  \033[38;5;113m✓\033[0m Banner" || echo -e "  \033[38;5;203m✗\033[0m Banner missing"
    [ -f "$WORK_LOGGER" ] && echo -e "  \033[38;5;113m✓\033[0m Work logger" || echo -e "  \033[38;5;203m✗\033[0m Work logger missing"
    [ -f "$PROFILE_MANAGER" ] && echo -e "  \033[38;5;113m✓\033[0m Profile manager" || echo -e "  \033[38;5;203m✗\033[0m Profile manager missing"

    # Count profiles
    local profile_count=0
    for p in "$MANGOLOVE_DIR/projects"/*.md; do
        [ "$(basename "$p")" = "README.md" ] && continue
        [ -f "$p" ] && profile_count=$((profile_count + 1))
    done
    echo -e "  \033[38;5;113m✓\033[0m Project profiles: ${profile_count}"

    # Count plugins
    local plugin_count=0
    for pd in "$MANGOLOVE_DIR/plugins"/*/; do
        [ -f "${pd}plugin.sh" ] && plugin_count=$((plugin_count + 1))
    done
    echo -e "  \033[38;5;113m✓\033[0m Plugins: ${plugin_count}"

    # Count modes
    local mode_count=0
    for mf in "$MANGOLOVE_DIR/prompts/modes"/*.md; do
        [ -f "$mf" ] && mode_count=$((mode_count + 1))
    done
    echo -e "  \033[38;5;113m✓\033[0m Modes: ${mode_count}"

    # Count skills
    local skill_count=0
    for sd in "$MANGOLOVE_DIR/skills"/*/; do
        [ -f "${sd}skill.yaml" ] || [ -f "${sd}skill.md" ] && skill_count=$((skill_count + 1))
    done
    echo -e "  \033[38;5;113m✓\033[0m Skills: ${skill_count}"

    echo ""
    echo -e "\033[2m──────────────────────────────────────\033[0m"
    echo ""
}

handle_log() {
    case "${1:-}" in
        init)
            bash "$WORK_LOGGER" init
            ;;
        view)
            local repo_full=""
            if [ -n "$MANGOLOVE_LOG_REPO" ] && [ "$MANGOLOVE_LOG_REPO" != "disabled" ]; then
                repo_full="$MANGOLOVE_LOG_REPO"
            else
                local gh_user
                gh_user=$(gh api user --jq '.login' 2>/dev/null)
                repo_full="${gh_user}/mangolove-work-logs"
            fi
            open "https://github.com/${repo_full}" 2>/dev/null || \
            echo "https://github.com/${repo_full}"
            ;;
        search)
            bash "$WORK_LOGGER" search "${2:-}"
            ;;
        recent)
            bash "$WORK_LOGGER" recent
            ;;
        *)
            echo "Usage: mangolove log [init|view|search|recent]"
            ;;
    esac
}

handle_skill() {
    case "${1:-}" in
        install) bash "$SKILL_MANAGER" install "$2" ;;
        remove)  bash "$SKILL_MANAGER" remove "$2" ;;
        update)  bash "$SKILL_MANAGER" update "${2:-}" ;;
        create)  bash "$SKILL_MANAGER" create "$2" ;;
        *)       bash "$SKILL_MANAGER" list ;;
    esac
}

handle_plugin() {
    case "${1:-}" in
        enable)  bash "$PLUGIN_MANAGER" enable "$2" ;;
        disable) bash "$PLUGIN_MANAGER" disable "$2" ;;
        create)  bash "$PLUGIN_MANAGER" create "$2" ;;
        *)       bash "$PLUGIN_MANAGER" list ;;
    esac
}

handle_profile() {
    case "${1:-}" in
        add)     bash "$PROFILE_MANAGER" add ;;
        remove)  bash "$PROFILE_MANAGER" remove "$2" ;;
        auto)    bash "$PROFILE_MANAGER" auto "${2:-}" ;;
        export)  bash "$PROFILE_MANAGER" export "$2" "${3:-}" ;;
        import)  bash "$PROFILE_MANAGER" import "${2:-}" ;;
        *)       bash "$PROFILE_MANAGER" list ;;
    esac
}

# ─────────────────────────────────────────────
# Main
# ─────────────────────────────────────────────
main() {
    export MANGOLOVE_DIR

    case "${1:-}" in
        help|--help|-h)
            show_help
            exit 0
            ;;
        --version|-v)
            show_version
            exit 0
            ;;
        projects)
            bash "$PROFILE_MANAGER" list
            exit 0
            ;;
        profile)
            shift
            handle_profile "$@"
            exit 0
            ;;
        skill|skills)
            shift
            handle_skill "$@"
            exit 0
            ;;
        plugin|plugins)
            shift
            handle_plugin "$@"
            exit 0
            ;;
        log)
            shift
            handle_log "$@"
            exit 0
            ;;
        update)
            do_update
            exit 0
            ;;
        doctor)
            do_doctor
            exit 0
            ;;
    esac

    # Parse --mode flag before passing to claude
    local remaining_args=()
    while [ $# -gt 0 ]; do
        case "$1" in
            --mode|-m)
                if [ -n "${2:-}" ]; then
                    MANGOLOVE_MODE="$2"
                    local mode_file="$MANGOLOVE_DIR/prompts/modes/${MANGOLOVE_MODE}.md"
                    if [ ! -f "$mode_file" ]; then
                        echo -e "\033[38;5;203m✗ Unknown mode: ${MANGOLOVE_MODE}\033[0m"
                        echo ""
                        echo "  Available modes:"
                        for mf in "$MANGOLOVE_DIR/prompts/modes"/*.md; do
                            [ -f "$mf" ] && echo "    - $(basename "$mf" .md)"
                        done
                        echo ""
                        exit 1
                    fi
                    shift 2
                else
                    echo "Usage: mangolove --mode <mode> [prompt]"
                    exit 1
                fi
                ;;
            *)
                remaining_args+=("$1")
                shift
                ;;
        esac
    done
    set -- "${remaining_args[@]}"

    # Preflight
    check_dependencies

    # Run plugin on_session_start hooks
    bash "$PLUGIN_MANAGER" hook on_session_start 2>/dev/null || true

    # Show banner
    if [ "$MANGOLOVE_SHOW_BANNER" = "true" ]; then
        bash "$BANNER_SCRIPT"
    fi

    # Log session start (background, non-blocking)
    if [ "$MANGOLOVE_AUTO_LOG" = "true" ]; then
        bash "$WORK_LOGGER" start &>/dev/null &
    fi

    # Build system prompt
    SYSTEM_PROMPT=$(build_system_prompt)

    # Trap exit to log session end and run plugin hooks
    # Use timeout to prevent hanging on network issues
    # shellcheck disable=SC2154
    trap '
        bash "$PLUGIN_MANAGER" hook on_session_end 2>/dev/null &
        _ml_plugin_pid=$!
        _ml_logger_pid=0
        if [ "$MANGOLOVE_AUTO_LOG" = "true" ]; then
            bash "$WORK_LOGGER" end 2>/dev/null &
            _ml_logger_pid=$!
        fi
        _ml_wait=0
        while [ $_ml_wait -lt 10 ]; do
            kill -0 $_ml_plugin_pid 2>/dev/null || kill -0 $_ml_logger_pid 2>/dev/null || break
            sleep 1
            _ml_wait=$((_ml_wait + 1))
        done
    ' EXIT

    # Build Claude args
    CLAUDE_ARGS=()
    CLAUDE_ARGS+=(--append-system-prompt "$SYSTEM_PROMPT")
    if [ -n "$MANGOLOVE_MODE" ]; then
        CLAUDE_ARGS+=(--name "🥭 MangoLove [${MANGOLOVE_MODE}]")
    else
        CLAUDE_ARGS+=(--name "🥭 MangoLove")
    fi

    [ -n "$MANGOLOVE_MODEL" ] && CLAUDE_ARGS+=(--model "$MANGOLOVE_MODEL")
    [ -n "$MANGOLOVE_EFFORT" ] && CLAUDE_ARGS+=(--effort "$MANGOLOVE_EFFORT")

    # Launch Claude Code
    claude "${CLAUDE_ARGS[@]}" "$@"
}

main "$@"
