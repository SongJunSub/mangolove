#!/bin/bash
# ─────────────────────────────────────────────
# 🥭 MangoLove — User Configuration
# ─────────────────────────────────────────────
# Copy this file to ~/.mangolove/config.sh and customize.
# Values here override defaults.
# ─────────────────────────────────────────────

# GitHub work log repository (default: auto-detected as {gh-username}/mangolove-work-logs)
# Set to "disabled" to turn off work logging entirely
MANGOLOVE_LOG_REPO=""

# Auto-log sessions to GitHub (true / false)
MANGOLOVE_AUTO_LOG=true

# Show banner on startup (true / false)
MANGOLOVE_SHOW_BANNER=true

# Extra text appended to system prompt (for personal preferences)
MANGOLOVE_EXTRA_PROMPT=""

# Default Claude model (leave empty to use Claude Code default)
MANGOLOVE_MODEL=""

# Default effort level (low / medium / high / max / auto)
MANGOLOVE_EFFORT=""

# Methodology delivery (monolith / split)
#   monolith — inject the full strict.md methodology every session (default; behavior parity).
#   split    — inject a lean core.md and load heavy Spec/review procedures on-demand as
#              cc-plugin skills. Cuts always-on tokens; falls back to monolith if incomplete.
MANGOLOVE_METHODOLOGY_MODE=monolith

# DoD gate (on / off) — 완료 직전 ./.mangolove/dod.sh 를 Stop 훅으로 결정적 검증
#   모델이 완료를 주장하기 전에 DoD 를 실행형 체크로 외부화하면, 통과 전까지 턴이 끝나지 않는다.
#   기본 off(옵트인). 세션 게이트 번들에 함께 주입되므로 MANGOLOVE_SESSION_GATES=true 필요.
MANGOLOVE_DOD_GATE=off
